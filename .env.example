DB_URL=postgresql://user:password@host:port/dbname
APP_PORT=8082

# Resend mail service
RESEND_API_KEY=your_resend_api_key
RESEND_FROM=your@email.com


# Slack webhook for daily leave notifications
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL/HappyBirthday

# Cron job authentication token (min 32 characters)
CRON_SECRET_TOKEN=your-random-secret-token-here-min-32-chars

EXTERNAL_API_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL/leave

