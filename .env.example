# Copy this file to .env and fill in your values.
# DO NOT commit .env to version control.

DB_URL=postgresql://user:password@host:port/dbname?sslmode=disable

APP_PORT=8082
App_URL=http://localhost:8089

# Application / company display name (used in email signatures and PDF headers)
APP_NAME=Leave Management System

# Resend mail service
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=leave@yourdomain.com

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8089

# Slack webhook for daily leave notifications
EXTERNAL_API_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Cron job authentication token (min 32 characters)
CRON_SECRET=your-random-cron-secret-min-32-chars-here

# Company email domain used for:
#   - Employee email validation (must end with @COMPANY_EMAIL_DOMAIN)
#   - Demo seed account generation  (demo.<role>@COMPANY_EMAIL_DOMAIN)
COMPANY_EMAIL_DOMAIN=yourdomain.com

# Password assigned to all demo/seed accounts (cmd/seed only)
DEMO_SEED_PASSWORD=Demo@1234
