# =========================
# Database
# =========================
DB_URL=postgresql://user:password@host:port/dbname?sslmode=disable

# =========================
# Server Config
# =========================

APP_PORT=8082
APP_URL=http://localhost:8089
APP_NAME=Leave Management System


# =========================
# Email Service (Resend)
# =========================

RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=leave@yourdomain.com

# =========================
# Frontend Access (CORS)
# =========================

ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8089

# =========================
# External Integrations (Slack)
# =========================
# Used for all Slack notifications: birthday announcements,
# daily leave summaries, and leave approval/rejection updates.

# SLACK_WEBHOOK_URL — posts the birthday announcement message to Slack.

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# EXTERNAL_API_URL — posts the daily leave summary message to Slack
# (who's on leave today). Triggered by the cron job below.

EXTERNAL_API_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# =========================
# Cron Job Security
# =========================

# CRON_SECRET is a random token (not a password you choose) that protects
# the daily leave summary endpoint from being triggered by anyone else.
# Generate it with: openssl rand -hex 32
#
# This token is NOT used inside the app's own scheduler — there isn't one.
# It is configured on the EXTERNAL cron service side (e.g. cron-job.org),
# which calls this endpoint daily using the token as a query parameter:
#
#   GET /api/cron/daily-leave-slack?token=CRON_SECRET
#
# Test it manually with curl:
#
#   curl "https://your-backend-url/api/cron/daily-leave-slack?token=YOUR_CRON_SECRET"
#
# A 200 OK response means the daily leave summary was sent to Slack successfully.

# Generate 32 random bytes (hex-encoded) with: openssl rand -hex 32
CRON_SECRET=your-random-cron-secret-min-32-chars-here

# =========================
# Company Rules / Domain Validation
# =========================
# Used for:
# - Email verification during signup/login
# - Restricting registration to company domain only
# Example: user must register with an @yourdomain.com address

COMPANY_EMAIL_DOMAIN=yourdomain.com

# =========================
# Demo / Seed Accounts
# =========================
DEMO_SEED_PASSWORD=Demo@1234
